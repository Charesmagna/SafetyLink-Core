on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '11'
          distribution: 'temurin'

      - name: Set up Android SDK
        uses: android-actions/setup-android@v3

      - name: Install Node.js 20
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: cordova platform add android@12.0.1 --save 
      - name: Install npm dependencies
        run: npm install

      - name: Add Android platform
        run: cordova platform add android@12 --save

      - name: Add required Cordova plugins
        run: |
          cordova plugin add cordova-plugin-device
          cordova plugin add cordova-plugin-geolocation@4.1.0
          cordova plugin add cordova-sms-plugin
          cordova plugin add mx.ferreyra.callnumber
          cordova plugin add cordova-plugin-android-permissions
          cordova plugin add cordova-plugin-whitelist

      - name: Build debug APK
        run: cordova build android --debug

      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: SafetyLink-debug.apk
          path: platforms/android/app/build/outputs/apk/debug/app-debug.apk
          if-no-files-found: warn
