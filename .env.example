# ============================================================
# SafetyLink-Core — Server & Client Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# .env is gitignored. NEVER commit real secrets.
# APKs can be decompiled — put secrets in server env only.
# ============================================================

# --- SERVER-SIDE ONLY (never prefix with VITE_) ---

# JWT signing secret for auth tokens
JWT_SECRET=change-me-in-production

# OpenRouter AI proxy — set this on your server/hosting provider.
# The client calls /api/ai/chat which reads this server-side.
# Direct in-app embedding is UNSUPPORTED because APKs are decompilable.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_REAL_KEY
OPENROUTER_REFERER=https://safetylink.app
OPENROUTER_TITLE=SafetyLink-Core

# --- CLIENT-SIDE (VITE_ prefix — bundled into shipped JS, no secrets here) ---

# Master intercept key — LEAVE EMPTY in production.
# Anyone reading the public repo can trigger real dispatch if this is set.
VITE_MASTER_INTERCEPT_KEY=

# ThingsBoard device token (entered in Admin Panel at runtime, not here)
VITE_THINGSBOARD_TOKEN=

# AI provider: 'webspeech' (default, offline) or 'klev' or 'openrouter'
# 'openrouter' routes through the backend proxy — no key needed client-side.
VITE_AI_PROVIDER=webspeech

# Backend base URL (leave empty for same-origin / Vite proxy in dev)
VITE_BACKEND_URL=

# K'lev.ai endpoint (optional, only used when VITE_AI_PROVIDER=klev)
VITE_KLEV_AI_ENDPOINT=
