# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY
# Master intercept key — dev only, leave empty for production
VITE_MASTER_INTERCEPT_KEY=
# ThingsBoard device token
VITE_THINGSBOARD_TOKEN=

# Authentication Secret
JWT_SECRET=

# Twilio Configuration for Voice/SMS Dispatch
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

BACKEND_URL=http://localhost:3000
NTFY_URL=http://localhost
OC_URL=http://localhost:8080
TWILIO_SID=ACxxxxx
TWILIO_TOKEN=xxxxx
TWILIO_FROM=+2787xxxxxxx
OC_ADMIN=safelinkadmin123
GEMINI_API_KEY=AIzaSyxxxxx
