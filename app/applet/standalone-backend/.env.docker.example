# Standalone Backend Docker Environment Variables

# Base URL for the Custom Backend
BACKEND_BASE_API_URL=http://localhost:4000
BACKEND_API_VERSION=v1
BACKEND_CHANNEL_HUB=eventingHub
BACKEND_REALTIME_HUB=geolocationHub

# OwnCloud Configuration for Evidence Storage
OC_URL=http://owncloud:8080
OC_ADMIN=admin
OC_ADMIN_PASS=admin_safetylink

# Database connection
DATABASE_URL=file:./dev.db

# Features
ENABLE_90_DAY_RETENTION_SWEEP=true
BACKEND_MAINTENANCE_MODE=false
