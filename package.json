{
  "name": "safetylink-core",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "build:prod": "npm run build && npx cap sync android",
    "cap:sync": "npx cap sync android",
    "branding": "node branding/generate-branding.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "tsx src/tests/run-tests.ts"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cordova-plugin-powermanagement": "^1.0.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.12",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.38",
    "svg2img": "^1.0.0-beta.2",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.23.1",
    "typescript": "^5.2.2",
    "vite": "^8.1.4"
  }
}
