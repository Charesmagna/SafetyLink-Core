{
  "name": "safetylink-core",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "cap:sync": "npx cap sync android",
    "branding": "node branding/generate-branding.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "tsx src/tests/run-tests.ts",
    "build:electron": "npm run build && electron-builder --win -c.extraMetadata.main=electron-main.cjs"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^6.0.0",
    "@capacitor-mlkit/barcode-scanning": "^6.2.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.4",
    "@capawesome-team/capacitor-android-foreground-service": "^6.2.0",
    "capacitor-voice-recorder": "6.0.3",
    "@google/genai": "^2.12.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.2",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "node-cron": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "twilio": "^6.0.2",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.12",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.4",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.19",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.safetylink.console",
    "productName": "SafetyLink Response Console",
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "public/**/*"
    ],
    "directories": {
      "output": "electron-dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "overrides": {
    "@capgo/capacitor-audio-recorder": {
      "@capacitor/core": "$@capacitor/core"
    }
  }
}