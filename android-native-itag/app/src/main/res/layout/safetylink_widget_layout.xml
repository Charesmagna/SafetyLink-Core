<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@android:color/black">

    <!-- Ambient Dark glassmorphic bento container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@android:drawable/dialog_holo_dark_frame">

        <!-- Top Header: Logo and Time -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️ SafetyLink Tactical"
                android:textColor="#E2E8F0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● ARMED"
                android:textColor="#10B981"
                android:textSize="8sp"
                android:textStyle="bold"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Bento Grid split into columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Left: Giant Big Red Panic Button (Short press: SOS, Long press: Arm/Disarm) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginRight="4dp">

                <Button
                    android:id="@+id/btn_widget_sos"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@android:drawable/presence_audio_online"
                    android:text="🆘\nSOS"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:shadowColor="#EF4444"
                    android:shadowRadius="10" />
            </LinearLayout>

            <!-- Right: Status Cards Stack -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.0"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginLeft="4dp">

                <!-- GNSS Lock indicator cell -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@android:color/black">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛰️ GNSS"
                        android:textColor="#94A3B8"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/widget_gps_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="LOCKED"
                        android:textColor="#06B6D4"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:gravity="right" />
                </LinearLayout>

                <!-- iTAG status indicator cell -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@android:color/black">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📟 iTAG"
                        android:textColor="#94A3B8"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/widget_itag_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CONNECTED"
                        android:textColor="#3B82F6"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:gravity="right" />
                </LinearLayout>

                <!-- MQTT Gateway ping latency cell -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp"
                    android:background="@android:color/black">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☁️ CLOUD"
                        android:textColor="#94A3B8"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/widget_gateway_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="42 ms"
                        android:textColor="#10B981"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:gravity="right" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
